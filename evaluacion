productos = {}
stock = {}

def menu():
    print("=============MENU PRINCIPAL=============")
    print("1. Unidades por categoria")
    print("2. Busqueda de productos por rango de precio")
    print("3. Actualizar precio de producto")
    print("4. Agregar producto")
    print("5. Eliminar producto")
    print("6. Salir")
    print("=========================================")

def leer_opcion():
    try:
        opcion = int(input("Ingrese un opcion: "))
        if opcion >= 1 and opcion <= 6:
            return opcion
    except ValueError:
        print("Debe seleccionar una opción válida" )

def unidades_categoria(categoria):
    categoria = input("Ingrrese la categoria a buscar: ")
    if categoria in productos.values():
        total_unidades = 0
        for producto in productos.values():
            if producto["categoria"] == categoria:
                total_unidades += producto["unidades"]
            print(f"Total de unidades en la categoria {categoria}: {total_unidades}")

def busqueda_precio(p_min, p_max):
    if p_min <= p_max and p_min > 0 and p_max > 0:
        productos_en_rango = []
        for codigo in stock:
            if p_min <= stock[codigo]["precio"] <= p_max and stock[codigo]["unidades"] > 0:
                productos_en_rango.append(f"{productos[codigo]['nombre']}--{codigo}")
        
def buscar_codigo(codigo):
    if codigo in productos:
        return True
    return False

def actualizar_precio(codigo, nuevo_precio):
    if buscar_codigo(codigo) and validar_precio(nuevo_precio):
        stock[codigo]["precio"] = nuevo_precio
        return True
    return False


def validar_codigo(codigo):
    if len(codigo) > 0:
        return True
    return False

def validar_nombre(nombre):
    if len(nombre) > 0:
        return True
    return False

def validar_categoria(categoria):
    if len(categoria) > 0:
        return True
    return False

def validar_marca(marca):
    if len(marca) > 0:
        return True
    return False

def validar_peso_kg(peso_kg):
    if peso_kg > 0:
        return True
    return False

def validar_es_importado(es_importado):
    if es_importado in ["si"]:
        es_importado = True
    
    elif es_importado in ["no"]:
        es_importado = False

        
def validar_es_para_cachorro(es_para_cachorro):
    if es_para_cachorro in ["si"]:
        es_para_cachorro = True
    elif es_para_cachorro in ["no"]:
        es_para_cachorro = False

def validar_precio(precio):
    if precio > 0:
        return True
    return False

def validar_unidades(unidades):
    if unidades > 0:
        return True
    return False

def agregar_producto(codigo, nombre, categoria, marca, peso_kg, es_importado, es_para_cachorro, precio, unidades):
    if validar_codigo(codigo) and validar_nombre(nombre) and validar_categoria(categoria) and validar_marca(marca) and validar_peso_kg(peso_kg) and validar_es_importado(es_importado) and validar_es_para_cachorro(es_para_cachorro) and validar_precio(precio) and validar_unidades(unidades):
        productos[codigo] = {
            "nombre": nombre,
            "categoria": categoria,
            "marca": marca,
            "peso_kg": peso_kg,
            "es_importado": es_importado,
            "es_para_cachorro": es_para_cachorro,
            "unidades": unidades
        }
        stock[codigo] = {
            "precio": precio,
            "unidades": unidades
        }
        return True
    return False

def eliminar_producto(codigo):
    if buscar_codigo(codigo):
        del productos[codigo]
        del stock[codigo]
        return True
    return False

while True:
    menu()
    opcion = leer_opcion()
    if opcion == 1:
        categoria = input("Ingrese la categoria a buscar: ")
        unidades_categoria(categoria)
    elif opcion == 2:
        p_min = int(input("Ingrese el precio minimo: "))
        p_max = int(input("Ingrese el precio maximo: "))
        busqueda_precio(p_min, p_max)
    elif opcion == 3:
        codigo = input("Ingrese el codigo del producto a actualizar: ")
        nuevo_precio = float(input("Ingrese el nuevo precio: "))
        if actualizar_precio(codigo, nuevo_precio):
            print("Precio actualizado")
        else:
            print("El codigo no existe")
    elif opcion == 4:
        codigo = input("Ingrese el codigo del producto: ")
        validar_codigo(codigo)
        nombre = input("Ingrese el nombre del producto: ")
        validar_nombre(nombre)
        categoria = input("Ingrese la categoria del producto: ")
        validar_categoria(categoria)
        marca = input("Ingrese la marca del producto: ")
        validar_marca(marca)
        peso_kg = float(input("Ingrese el peso en kg del producto: "))
        validar_peso_kg(peso_kg)
        es_importado = input("El producto es importado? (s/n): ")
        validar_es_importado(es_importado)
        es_para_cachorro = input("El proiducto es para cachorro? (s/n): ")
        validar_es_para_cachorro(es_para_cachorro)
        precio = float(input("Ingrese el precio del producto: "))
        validar_precio(precio)
        unidades = int(input("Ingrese la cantidad de unidades del prodcuto: "))
        validar_unidades(unidades)
        if agregar_producto(codigo, nombre, categoria, marca, peso_kg, es_importado, es_para_cachorro, precio, unidades):
            print("Producto agregado")
        else:
            print("Error al agregar producto")
    elif opcion == 5:
        eliminar_producto(codigo)
    elif opcion == 6:
        print("Programa finalizado")
        break
    
        
